params{
    outdir="./results/"
}
process{
    withName: "convert_pyramid"{
        container = "oras://community.wave.seqera.io/library/libvips:8.17.3--73bbb05066bc0731"
        memory = "10G"
        cpus = 1
	    clusterOptions = "--exclude=toki-hm-1"
    }
}

profiles {
    kutral {
        singularity.enabled     = true
        singularity.autoMounts  = true
	    singularity.runOptions = ' --bind /mnt/beegfs/labs/ '
        conda.enabled           = false
        docker.enabled          = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
        process.executor = 'slurm'
        process.queue = 'ngen-ko'
        executor.queueSize = 50
    }
    local {
        singularity.enabled     = true
        singularity.autoMounts  = true
	    singularity.runOptions = ' --bind /mnt/beegfs/labs/ '
        conda.enabled           = false
        docker.enabled          = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
    }
    stub {
        process {
            withName: '.*' {
                cpus   = 1
                memory = '1 MB'
                time   = '5 min'
            }
        }
        docker.enabled = false
        singularity.enabled = false
        conda.enabled = false
        podman.enabled = false
        shifter.enabled = false
        charliecloud.enabled = false
        apptainer.enabled = false
    }
}
timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_timeline_${new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')}.html"
}
report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_report_${new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')}.html"
}
trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_trace_${new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')}.txt"
}
dag {
    enabled = true
    file    = "${params.outdir}/pipeline_info/pipeline_dag_${new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')}.html"
}
manifest {
    defaultBranch = 'main'
    author = 'Gabriel Cabas'
    version = '0.0.1'
}
